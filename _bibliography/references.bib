@InProceedings{	  Desolda2025Designing,
  title		= {Designing and {{Evaluating Human-Centred AI Systems}}:
		  {{Best-Practices}} from a {{Multidisciplinary View}}},
  booktitle	= {Joint {{Proceedings}} of the {{ACM IUI Workshops}} 2025},
  author	= {Desolda, Giuseppe and Esposito, Andrea and Lanzilotti,
		  Rosa and Piccinno, Antonio},
