@InProceedings{	  Esposito2025Metric,
  title		= {Toward a {{Metric}} for {{Evaluating Trust}} in
		  {{Human-Centered Artificial Intelligence}}},
  booktitle	= {Joint {{Proceedings}} of the {{ACM IUI Workshops}} 2025},
  author	= {Esposito, Andrea and Desolda, Giuseppe and Lanzilotti,
		  Rosa},
  year		= 2025,
  month		= mar,
  series	= {{{CEUR Workshop Proceedings}}},
  volume	= {3957},
  pages		= {119--127},
  publisher	= {CEUR-WS},
  address	= {Cagliari, Italy},
  url		= {https://ceur-ws.org/Vol-3957/AXAI-paper13.pdf},
  abstract	= {Trust is a critical human factor in the adoption and
		  effectiveness of artificial intelligence (AI) systems,
		  especially in high-risk domains such as medicine and
		  cybersecurity. This paper introduces a novel probabilistic
		  metric to objectively quantify trust in AI systems, using
		  the degree of reliance on AI by human users as a proxy. The
		  proposed metric leverages changes in human decision-making
		  influenced by AI decisions and can be computed using a
		  flexible data-driven approach. To validate this metric, we
		  present user study protocols applicable to diverse domains,
		  providing examples in the medical field (for Alzheimer's
		  disease detection) and cybersecurity (for phishing
		  detection). These protocols employ a frequentist definition
		  of probability to estimate and compute trust, allowing for
		  a comparison with trust questionnaires to establish
		  correlations. This work aims to contribute a standardized,
		  interpretable, and adaptable method for evaluating trust in
		  human-centered AI systems.},
  copyright	= {CC BY 4.0},
  langid	= {english},
  keywords	= {funding/devprodev,funding/fair,funding/protect,notion,reach/international,type/workshop},
  file		= {/Users/andreaesposito/Zotero/storage/WL7XRVXY/Esposito et
		  al. - 2025 - Toward a Metric for Evaluating Trust in
		  Human-Centered Artificial Intelligence.pdf}
}

